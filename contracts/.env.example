# Copy to .env and fill in (never commit .env):
#   cp .env.example .env

# Deployer private key (hex). With or without 0x prefix is fine.
# Use a dedicated burner / test wallet — never your main seed in chat or git.
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Monad testnet RPC
MONAD_RPC=https://testnet-rpc.monad.xyz

# Optional mainnet
# MONAD_MAINNET_RPC=https://rpc.monad.xyz

# Set true for 2-minute default cool-off (easier demos)
# DEMO=true
